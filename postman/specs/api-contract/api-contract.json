                      "type": "string",
                      "format": "utc-millisec"
                    }
                  },
                  "respuestaCorrecta": {
                    "type": "string",
                    "format": "utc-millisec"
                  },
                  "examenId": {
                    "type": "integer"
                  }
                }
              },
              "example": {
                "tipo": "MULTIPLE_CHOICE",
                "texto": "¿En qué año cayó el muro de Berlín?",
                "opciones": [
                  "1987",
                  "1989",
                  "1991",
                  "1993"
                ],
                "respuestaCorrecta": "1989",
                "examenId": 2
              }
            }
